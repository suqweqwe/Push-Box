<Page x:Class="SokobanGame.MapSelectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="MapSelectPage"
      Loaded="Page_Loaded"
      Margin="0" 
    Background="#0f172a">
    <!-- 深色背景，无白色 -->

    <Page.Resources>
        <QuadraticEase x:Key="QuadraticEaseOut" EasingMode="EaseOut"/>
    </Page.Resources>

    <!-- 全屏容器，无留白 -->
    <Grid>
        <!-- 全屏星空背景（覆盖整个窗口） -->
        <Canvas x:Name="StarsCanvas" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <!-- 内容容器，居中显示 -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <!-- 标题行 -->
                <RowDefinition Height="Auto"/>
                <!-- 按钮列表行 -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="600"/>
                <!-- 中间内容宽度 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 标题 -->
            <TextBlock Grid.Row="1" Grid.Column="1" 
                       Text="选择地图" 
                       FontSize="64" 
                       FontFamily="微软雅黑 Bold"
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,60" 
                       Foreground="#e2e8f0">  
                <TextBlock.Effect>
                    <DropShadowEffect 
                        Color="#38bdf8" 
                        BlurRadius="15" 
                        ShadowDepth="4"/>
                </TextBlock.Effect>
                <TextBlock.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation 
                                    Storyboard.TargetProperty="Opacity"
                                    From="0" To="1" Duration="0:0:1.5"/>
                                <DoubleAnimation 
                                    Storyboard.TargetProperty="RenderTransform.Y"
                                    From="-30" To="0" Duration="0:0:1.5" 
                                    EasingFunction="{StaticResource QuadraticEaseOut}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </TextBlock.Triggers>
                <TextBlock.RenderTransform>
                    <TranslateTransform Y="0"/>
                </TextBlock.RenderTransform>
            </TextBlock>

            <!-- 地图按钮容器 -->
            <ScrollViewer Grid.Row="2" Grid.Column="1" 
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         Margin="20">
                <StackPanel x:Name="MapButtonsPanel" 
                           Orientation="Vertical" 
                           HorizontalAlignment="Center">
                    <!-- 按钮将动态生成 -->
                </StackPanel>
            </ScrollViewer>

            <!-- 返回按钮 -->
            <Border Grid.Row="3" Grid.Column="1" 
                    Margin="10,40,10,60"  
                    CornerRadius="15"
                    Width="200"
                    Height="70">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#2a1e3a" Offset="0"/>
                        <GradientStop Color="#3a2a4a" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#9D4EDD" Offset="0"/>
                        <GradientStop Color="#7B2CBF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>
                    <Thickness>2</Thickness>
                </Border.BorderThickness>
                <Border.Effect>
                    <DropShadowEffect Color="#9D4EDD" BlurRadius="15" Opacity="0.5" ShadowDepth="0"/>
                </Border.Effect>
                <Button Content="返回" 
                        FontSize="26" 
                        FontWeight="Bold"
                        Height="70"
                        Click="Back_Click"
                        Foreground="#FFFFFF" 
                        Background="Transparent"
                        BorderBrush="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#9D4EDD"/>
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="1.08" ScaleY="1.08"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Border>
        </Grid>
    </Grid>
</Page>