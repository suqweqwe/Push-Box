<Page x:Class="SokobanGame.GamePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="GamePage"
      KeyDown="Page_KeyDown"
      Focusable="True">

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 左侧信息面板 -->
        <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Background="#2D2D2D" BorderBrush="#555555" BorderThickness="0,0,2,0">
            <StackPanel Margin="15" VerticalAlignment="Top">
                <Button Content="返回选择地图" FontSize="14" Margin="0,0,0,20" Padding="10,5" Click="BackToMapSelect_Click"/>
                
                <!-- 步数显示 -->
                <TextBlock Text="步数统计" FontSize="16" Foreground="White" FontWeight="Bold" Margin="0,0,0,10"/>
                <Border Background="#1E1E1E" BorderBrush="#555555" BorderThickness="1" Padding="10" Margin="0,0,0,20">
                    <TextBlock x:Name="StepCountText" Text="0" FontSize="24" Foreground="#4CAF50" HorizontalAlignment="Center" FontWeight="Bold"/>
                </Border>
                
                <!-- 撤回按钮 -->
                <Button x:Name="UndoButton" Content="撤回上一步" FontSize="14" Padding="10,8" Margin="0,0,0,10" 
                        Click="UndoButton_Click" IsEnabled="False" Background="#3D3D3D" Foreground="White" BorderBrush="#555555"/>
                
                <TextBlock Text="提示：按 R 键重置关卡" FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <!-- 顶部按钮（移到右侧） -->
        <Button Grid.Column="1" Content="重置关卡" FontSize="14" Margin="10" HorizontalAlignment="Right" Click="ResetButton_Click"/>

        <!-- 游戏区域使用Viewbox来自动缩放 -->
        <Viewbox Grid.Column="1" Grid.Row="1" Stretch="Uniform" Margin="20">
            <Grid x:Name="GameGrid" ShowGridLines="False">
                <!-- 行和列将在代码中动态生成 -->
            </Grid>
        </Viewbox>

        <!-- 通关提示 -->
        <Grid x:Name="SuccessGrid" Grid.Column="1" Grid.Row="1" Visibility="Hidden" Background="Black" Opacity="0.8" Panel.ZIndex="100">
            <TextBlock Text="恭喜通关！" FontSize="72" Foreground="Yellow" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>